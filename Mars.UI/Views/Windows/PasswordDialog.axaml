<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:Mars.UI.Services"
        x:Class="Mars.UI.Views.Windows.PasswordDialog"
        Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PasswordDialog.Title]}"
        Width="400" Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
        ExtendClientAreaToDecorationsHint="True">
    
    <Grid RowDefinitions="*, Auto" Margin="20, 40, 20, 20">
        <StackPanel Spacing="15" VerticalAlignment="Center">
            <TextBlock x:Name="MessageTextBlock" 
                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PasswordDialog.Message]}" 
                       TextWrapping="Wrap" 
                       FontSize="14" />
            <TextBox x:Name="PasswordTextBox" 
                     PasswordChar="•" 
                     Watermark="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PasswordDialog.Watermark]}" />
        </StackPanel>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button x:Name="ConnectButton" 
                    Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PasswordDialog.Connect]}" 
                    Classes="Accent" 
                    IsDefault="True"
                    Click="ConnectButton_Click" 
                    Padding="20,8"/>
            <Button x:Name="CancelButton" 
                    Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PasswordDialog.Cancel]}" 
                    IsCancel="True"
                    Click="CancelButton_Click" 
                    Padding="20,8"/>
        </StackPanel>
    </Grid>
</Window>
