<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Mars.UI.Views.Windows.MessageDialog"
        Title="Message"
        Width="400" Height="200"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">

    <Border BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <Grid RowDefinitions="Auto,*,Auto" Margin="20,40,20,20">
            <TextBlock x:Name="TitleTextBlock" Text="Message" FontWeight="Bold" FontSize="18" Grid.Row="0" HorizontalAlignment="Center"/>
            <TextBlock x:Name="MessageTextBlock" Text="..." TextWrapping="Wrap" Grid.Row="1" Margin="0,15,0,15" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
            
            <Button Content="OK" Click="OkButton_Click" Grid.Row="2" HorizontalAlignment="Center" Width="100" HorizontalContentAlignment="Center"/>
        </Grid>
    </Border>
</Window>
