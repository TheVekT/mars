<Window
    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
    ExtendClientAreaToDecorationsHint="True"
    Height="550"
    MinHeight="550"
    MinWidth="800"
    Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Marketplace.Title]}"
    TransparencyLevelHint="Mica"
    Width="800"
    WindowStartupLocation="CenterOwner"
    d:DesignHeight="450"
    d:DesignWidth="600"
    mc:Ignorable="d"
    x:Class="Mars.UI.Views.Windows.MarketplaceWindow"
    x:DataType="vm:MarketplaceWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:services="clr-namespace:Mars.UI.Services"
    xmlns:views="clr-namespace:Mars.UI.Views"
    xmlns:vm="clr-namespace:Mars.UI.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20,40,20,20" RowDefinitions="Auto, *, Auto">
        <!--  Header  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,20"
            Spacing="5">
            <TextBlock
                FontSize="24"
                FontWeight="Bold"
                Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Marketplace.Title]}" />
            <TextBlock
                FontSize="14"
                Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Marketplace.SubTitle]}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!--  Module List  -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="25">
                <!--  Updates Section  -->
                <StackPanel IsVisible="{Binding HasUpdates}" Spacing="10">
                    <TextBlock FontSize="16" FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource StringFormatConverter}">
                                <Binding Path="[Marketplace.Headers.Updates]" Source="{x:Static services:LocalizationService.Instance}" />
                                <Binding Path="UpdatesCount" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding Updates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:SelectableModuleItem">
                                <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,10">
                                    <CheckBox
                                        Grid.Column="0"
                                        IsChecked="{Binding IsSelected}"
                                        Margin="10,0,20,0"
                                        VerticalAlignment="Center" />
                                    <views:ModuleItemView
                                        Grid.Column="1"
                                        views:ModuleItemView.Module="{Binding Module}"
                                        views:ModuleItemView.ShowActions="False" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!--  New Modules Section  -->
                <StackPanel IsVisible="{Binding HasNewModules}" Spacing="10">
                    <TextBlock FontSize="16" FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource StringFormatConverter}">
                                <Binding Path="[Marketplace.Headers.NewModules]" Source="{x:Static services:LocalizationService.Instance}" />
                                <Binding Path="NewModulesCount" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding NewModules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:SelectableModuleItem">
                                <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,10">
                                    <CheckBox
                                        Grid.Column="0"
                                        IsChecked="{Binding IsSelected}"
                                        Margin="10,0,20,0"
                                        VerticalAlignment="Center" />
                                    <views:ModuleItemView
                                        Grid.Column="1"
                                        views:ModuleItemView.Module="{Binding Module}"
                                        views:ModuleItemView.ShowActions="False" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!--  Footer / Install Button  -->
        <Border
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            CornerRadius="8"
            Grid.Row="2"
            Margin="0,15,0,0"
            Padding="15">
            <Grid ColumnDefinitions="*, Auto">
                <TextBlock
                    FontSize="14"
                    Grid.Column="0"
                    VerticalAlignment="Center">
                    <Run Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Marketplace.SelectedCount]}" />
                    <Run FontWeight="Bold" Text="{Binding SelectedCount}" />
                </TextBlock>
                <Button
                    Classes="Accent"
                    Click="InstallButton_OnClick"
                    Grid.Column="1"
                    IsEnabled="{Binding CanInstall}"
                    Padding="20,8"
                    x:Name="InstallButton">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon
                            Data="M352-120H200q-33 0-56.5-23.5T120-200v-152q48 0 84-30.5t36-77.5q0-47-36-77.5T120-568v-152q0-33 23.5-56.5T200-800h160q0-42 29-71t71-29q42 0 71 29t29 71h160q33 0 56.5 23.5T800-720v160q42 0 71 29t29 71q0 42-29 71t-71 29v160q0 33-23.5 56.5T720-120H568q0-50-31.5-85T460-240q-45 0-76.5 35T352-120Z"
                            Height="14"
                            Width="14" />
                        <TextBlock
                            FontSize="14"
                            Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Marketplace.Buttons.Install]}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
