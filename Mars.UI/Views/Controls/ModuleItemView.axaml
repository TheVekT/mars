<UserControl
    mc:Ignorable="d"
    x:Class="Mars.UI.Views.ModuleItemView"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Mars.Shared.Models;assembly=Mars.Shared"
    xmlns:services="clr-namespace:Mars.UI.Services"
    xmlns:views="clr-namespace:Mars.UI.Views"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <GeometryGroup x:Key="Icon.Trash">
            <Geometry>M6.66675 7.33333V11.3333</Geometry>
            <Geometry>M9.33325 7.33333V11.3333</Geometry>
            <Geometry>M12.6666 4V13.3333C12.6666 13.687 12.5261 14.0261 12.2761 14.2761C12.026 14.5262 11.6869 14.6667 11.3333 14.6667H4.66659C4.31296 14.6667 3.97382 14.5262 3.72378 14.2761C3.47373 14.0261 3.33325 13.687 3.33325 13.3333V4</Geometry>
            <Geometry>M2 4H14</Geometry>
            <Geometry>M5.33325 3.99999V2.66666C5.33325 2.31304 5.47373 1.9739 5.72378 1.72385C5.97383 1.4738 6.31296 1.33333 6.66659 1.33333H9.33325C9.68687 1.33333 10.026 1.4738 10.2761 1.72385C10.5261 1.9739 10.6666 2.31304 10.6666 2.66666V3.99999</Geometry>
        </GeometryGroup>
    </UserControl.Resources>

    <Border
        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
        BorderThickness="1"
        CornerRadius="4"
        Margin="0,0,0,8"
        Padding="12">
        <Grid ColumnDefinitions="*, Auto">
            <!--  Info section  -->
            <StackPanel Grid.Column="0" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.Module).Name}" />
                    <Border Classes="Badge">
                        <TextBlock Text="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.Module).Version, StringFormat='v{0}'}" />
                    </Border>
                    <ItemsControl ItemsSource="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.Module).Compatibility}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="Badge PlatformBadge" Tag="{Binding}">
                                    <TextBlock Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <TextBlock
                    FontSize="12"
                    Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    IsVisible="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.Module).Author, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Text="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.Module).Author, StringFormat='by {0}'}" />

                <TextBlock
                    FontSize="13"
                    Margin="0,4,0,0"
                    Opacity="0.7"
                    Text="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.Module).Description}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <!--  Actions section  -->
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Center"
                IsVisible="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.ShowActions)}">

                <!--  Enable Button (Visible when IsDisabled = True)  -->
                <Button
                    Command="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.EnableCommand)}"
                    CommandParameter="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.Module)}"
                    Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ModuleView.Buttons.Enable]}"
                    FontSize="12"
                    IsVisible="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.Module).IsDisabled}" />

                <!--  Disable Button (Visible when IsDisabled = False)  -->
                <Button
                    Command="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.DisableCommand)}"
                    CommandParameter="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.Module)}"
                    Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ModuleView.Buttons.Disable]}"
                    FontSize="12"
                    IsVisible="{Binding !$parent[views:ModuleItemView].(views:ModuleItemView.Module).IsDisabled}" />

                <!--  Delete Button  -->
                <Button Command="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.DeleteCommand)}" CommandParameter="{Binding $parent[views:ModuleItemView].(views:ModuleItemView.Module)}">
                    <Viewbox
                        Height="16"
                        HorizontalAlignment="Left"
                        Margin="0"
                        Width="16">
                        <Path
                            Data="{StaticResource Icon.Trash}"
                            Stroke="#FF5467"
                            StrokeJoin="Round"
                            StrokeLineCap="Round"
                            StrokeThickness="1.2" />
                    </Viewbox>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
